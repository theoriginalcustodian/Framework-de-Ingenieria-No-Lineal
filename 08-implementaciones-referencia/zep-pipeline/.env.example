# Zep — proyecto dedicado `inl-framework`
# Obtener la API key desde el dashboard de Zep Cloud (getzep.com) tras crear
# el proyecto `inl-framework`. Nunca commitear la key real — solo en `.env` local.
ZEP_API_KEY=z_REEMPLAZAR_CON_KEY_DEL_PROYECTO_INL

# Batch y asfixia controlada (lecciones ARCA 7-8)
BATCH_SIZE=20
SLEEP_MS=1500

# Timezone bitemporal (R7 FIX, HM-4)
TZ=America/Argentina/Buenos_Aires

# Polling bitemporal (leccion ARCA 12)
POLL_TIMEOUT_MS=180000

# Reingesta manual (leccion ARCA 13) — CSV de paths relativos al repo
FORCE_FILES=

# Audit entropia — threshold de fallo (ADR-001 HM-2)
EDGE_ENTROPY_THRESHOLD=0.15
