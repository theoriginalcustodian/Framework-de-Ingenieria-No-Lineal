{
  "name": "zep-pipeline-inl",
  "version": "0.2.0-fase2.0",
  "description": "Pipeline híbrido Python (ontología) + Node.js (ingesta) para el cerebro Zep del Framework INL. Librería lib/ compartida con ARCA (ADR-002).",
  "private": true,
  "scripts": {
    "bootstrap:canonical": "node ingesters/canonical_ingester.js",
    "bootstrap:canonical:dry": "node ingesters/canonical_ingester.js --dry-run",
    "bootstrap:evidence": "node ingesters/evidence_ingester.js",
    "bootstrap:evidence:dry": "node ingesters/evidence_ingester.js --dry-run",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@getzep/zep-cloud": "^2.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
